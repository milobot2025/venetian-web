      "unique": false
    },
    "slug": {
      "type": "uid",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "productos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::producto.producto",
      "mappedBy": "category"
    }
  }
}